<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
 xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
 xmlns:local="clr-namespace:StudentAttendanceApp.Model"
 x:Class="StudentAttendanceApp.MainPage"
 >

    <VerticalStackLayout Padding="20">

        <Button Text="Add Student"
                Command="{Binding ShowPopupCommand}" />

        <CollectionView ItemsSource="{Binding Students}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" Padding="10">
                        <VerticalStackLayout>

                            <Label Text="{Binding Name}" FontSize="18"/>

                            <Label Text="{Binding Percentage, StringFormat='Attendance: {0:F1}%'}"/>

                            <HorizontalStackLayout>

                                
                                <Button Text="Present"
Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PresentCommand}"
CommandParameter="{Binding .}" />

                                
                                <Button Text="Absent"
Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbsentCommand}"
CommandParameter="{Binding .}" />

                                
                                <Button Text="Delete"
Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
CommandParameter="{Binding .}" />

                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>