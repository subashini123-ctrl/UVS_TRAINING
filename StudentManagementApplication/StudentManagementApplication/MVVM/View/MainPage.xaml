<?xml version="1.0" encoding="utf-8" ?>
<TabbedPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudentManagementApplication.MVVM.View.MainPage"
             Title="MainPage">
    <ContentPage Title="Students">
        <CollectionView ItemsSource="{Binding Students}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="10" Padding="10" BorderColor="Gray">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="20"/>
                            <Label Text="{Binding RegisterNumber}"/>
                            <Label Text="{Binding Department}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </ContentPage>

    <!-- MARKSHEET -->
    <ContentPage Title="Marksheet">
        <CollectionView ItemsSource="{Binding Students}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="10" Padding="10" BorderColor="Blue">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="18"/>
                            <Label Text="{Binding Tamil, StringFormat='Tamil: {0}'}" />
                            <Label Text="{Binding English, StringFormat='English: {0}'}" />
                            <Label Text="{Binding Mathematics, StringFormat='Maths: {0}'}" />
                            <Label Text="{Binding Total, StringFormat='Total: {0}'}" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </ContentPage>
    
</TabbedPage>